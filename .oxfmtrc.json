{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": {
    "newlinesBetween": true,
    "customGroups": [
      { "groupName": "react", "elementNamePattern": ["react", "react-**", "next", "next-**"] }
    ],
    "groups": [
      "react",
      ["value-builtin", "value-external"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "sortPackageJson": false,
  "ignorePatterns": ["node_modules", "**/dist", "**/.next", "**/out", "coverage", "pnpm-lock.yaml"]
}
