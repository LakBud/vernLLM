{
  "name": "vern-llm",
  "version": "1.0.0",
  "description": "Retry, timeout, caching, and circuit breaker for OpenAI-compatible LLM calls, Groq, Anthropic, Gemini, Bedrock, and more.",
  "keywords": [
    "llm",
    "ai",
    "openai",
    "openai-compatible",
    "anthropic",
    "gemini",
    "groq",
    "bedrock",
    "language-model",
    "ai-sdk",
    "llm-client",
    "retry",
    "timeout",
    "caching",
    "circuit-breaker",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:int": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "openai": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "openai": "^6.48.0",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.14.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LakBud/vernLLM",
    "directory": "packages/vern-llm"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
