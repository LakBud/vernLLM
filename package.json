{
  "name": "vern-llm-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck:vern-llm": "pnpm --filter vern-llm run typecheck",
    "typecheck:test:vern-llm": "pnpm --filter vern-llm run typecheck:test",
    "test:vern-llm": "pnpm --filter vern-llm run test",
    "build:vern-llm": "pnpm --filter vern-llm run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,js}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pnpm": "^11.15.0"
  },
  "packageManager": "pnpm@11.15.0"
}
